{
    "name": "yebto/article-generator-api",
    "description": "PHP SDK for the YEB Article Generator API. Generate and validate articles with AI.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "yeb",
        "api",
        "sdk",
        "laravel",
        "php",
        "article",
        "content",
        "generator",
        "ai"
    ],
    "homepage": "https://yeb.to",
    "support": {
        "email": "support@yeb.to",
        "issues": "https://github.com/yebto/article-generator-api/issues",
        "source": "https://github.com/yebto/article-generator-api"
    },
    "authors": [
        {
            "name": "NETOX Ltd.",
            "email": "support@yeb.to",
            "homepage": "https://yeb.to",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "yebto/api-client": "^1.0"
    },
    "suggest": {
        "illuminate/support": "Required for Laravel Facade & ServiceProvider integration (^10.0|^11.0|^12.0)"
    },
    "autoload": {
        "psr-4": {
            "Yebto\\ArticleGeneratorAPI\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Yebto\\ArticleGeneratorAPI\\ArticleGeneratorAPIServiceProvider"
            ],
            "aliases": {
                "ArticleGeneratorAPI": "Yebto\\ArticleGeneratorAPI\\Facades\\ArticleGeneratorAPI"
            }
        }
    }
}
